{
  "name": "kestrel",
  "displayName": "Kestrel",
  "description": "Language support for the Kestrel programming language",
  "version": "0.1.0",
  "publisher": "kestrel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:kestrel"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kestrel",
        "aliases": ["Kestrel"],
        "extensions": [".ks"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kestrel",
        "scopeName": "source.kestrel",
        "path": "./syntaxes/kestrel.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Kestrel",
      "properties": {
        "kestrel.lsp.path": {
          "type": "string",
          "default": "kestrel-lsp",
          "description": "Path to the kestrel-lsp binary. Defaults to discovering it on PATH."
        },
        "kestrel.lsp.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP messages between VSCode and kestrel-lsp."
        },
        "kestrel.stdlibPath": {
          "type": "string",
          "default": "",
          "description": "Override the Kestrel stdlib search path. Leave empty to use the compiler's default."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
