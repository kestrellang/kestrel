{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kestrel",
  "scopeName": "source.kestrel",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kestrel",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kestrel",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kestrel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kestrel",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.kestrel",
              "begin": "\\\\\\(",
              "end": "\\)",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.kestrel",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.kestrel",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kestrel",
          "match": "\\b(if|else|while|for|in|return|break|continue|match|guard|defer)\\b"
        },
        {
          "name": "keyword.declaration.kestrel",
          "match": "\\b(let|var|func|struct|enum|protocol|extension|module|import|typealias|case)\\b"
        },
        {
          "name": "keyword.modifier.kestrel",
          "match": "\\b(public|private|internal|static|mutating|override)\\b"
        },
        {
          "name": "constant.language.kestrel",
          "match": "\\b(true|false|nil|self|Self)\\b"
        },
        {
          "name": "keyword.operator.new.kestrel",
          "match": "\\b(as|is)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.kestrel",
          "match": "\\b(Int|Float|Bool|String|Void|Any|Never)\\b"
        },
        {
          "name": "entity.name.type.kestrel",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.kestrel",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kestrel",
          "match": "(\\+|\\-|\\*|/|%|==|!=|<=|>=|<|>|&&|\\|\\||!|=|\\+=|\\-=|\\*=|/=|->|=>)"
        }
      ]
    }
  }
}
