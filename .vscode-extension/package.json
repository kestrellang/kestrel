{
  "name": "kestrel-lsp",
  "displayName": "Kestrel",
  "description": "Language support for Kestrel",
  "version": "0.0.1",
  "publisher": "kestrel",
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onLanguage:kestrel"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kestrel",
        "extensions": [".ks"],
        "aliases": ["Kestrel", "kestrel"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kestrel",
        "scopeName": "source.kestrel",
        "path": "./syntaxes/kestrel.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
