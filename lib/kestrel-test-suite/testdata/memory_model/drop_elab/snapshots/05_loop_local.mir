func Test.example() -> ()
{
    locals:
        %h: Test.Handle
        %_t0: Test.Handle

    bb0:
        jump bb1

    bb1:
        scope_live %self
        %_t0 = construct Test.Handle { fd: i64.literal 1 }
        %self = move %_t0
        call Test.consume(move %self)
        jump bb2

    bb2:
        return ()
}