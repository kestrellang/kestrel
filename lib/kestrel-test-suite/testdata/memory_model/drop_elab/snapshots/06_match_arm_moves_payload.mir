func Test.example(o: &Test.Opt) -> ()
{
    locals:
        %payload: Test.Handle
        %_t0: ()
        %_init_payload: bool

    bb0:
        %_init_payload = false
        switch %self {
    Test.Opt.some => bb2
    Test.Opt.none => bb3
}

    bb1:
        return copy %_t0

    bb2:
        switch %self.some.0 {
    _ => bb4
}

    bb3:
        %_t0 = ()
        jump bb1

    bb4:
        %payload = copy %self.some.0
        %_init_payload = true
        call Test.consume(move %payload)
        %_init_payload = false
        %_t0 = ()
        jump bb1
}